            </conditions>
            <connector>
                <targetReference>Task_After_Closed_Won_Stage</targetReference>
            </connector>
            <label>Stage Changed to Closed Won</label>
        </rules>
        <rules>
            <name>Stage_Changed_to_Closed_Lost</name>
