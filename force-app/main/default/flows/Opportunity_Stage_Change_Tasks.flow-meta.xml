            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Proposal/Price Quote</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.StageName</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Proposal/Price Quote</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Task_After_Proposal_Stage</targetReference>
            </connector>
            <label>Stage Changed to Proposal / Quote</label>
        </rules>
        <rules>
            <name>Stage_Changed_to_Negotiation</name>
